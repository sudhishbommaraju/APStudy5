# Proofly backend configuration
#
# Paste ONE API key below to enable REAL AI generation (notes, flashcards,
# practice). Without a key the app runs in DEMO MODE: everything renders and
# is navigable, but AI output is simulated.

# OpenAI (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic (alternative — get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Optional overrides:
# LLM_PROVIDER=openai          # force a provider (openai | anthropic)
# LLM_MODEL=gpt-4o             # default: gpt-4o-mini (OpenAI) / claude-sonnet-4-6 (Anthropic)
# PORT=8787

# Google Sign-In (optional) — paste your OAuth Client ID (…apps.googleusercontent.com)
# to enable the real "Continue with Google" button.
VITE_GOOGLE_CLIENT_ID=
